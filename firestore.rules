rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuário só pode ler/escrever seu próprio documento em /users/{userId}
    // e qualquer subcoleção dentro dele (lancamentos, categories, etc).
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      // Criação do doc do usuário: só ele mesmo pode criar, com o próprio uid.
      allow create: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Bloqueia qualquer outra coleção/documento não previsto explicitamente acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
